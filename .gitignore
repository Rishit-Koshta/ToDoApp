# --- Java & Spring Boot ---
*.class
target/
build/
out/
bin/
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# --- Configuration & Secrets ---
# We ignore .env and local properties, but NOT the main application.properties
.env
application-local.properties
application-dev.properties

# --- Maven ---
# We keep .mvn/wrapper so ./mvnw works for everyone
# But we ignore the help/temp files Maven generates
.mvn/help.log
.mvn/timing.properties

# --- IntelliJ IDEA ---
.idea/
*.iws
*.iml
*.ipr
# Ignore specific workspace settings
out/
cmake-build-*/

# --- VS Code ---
# Useful since you use VS Code for React/Frontend
.vscode/

# --- Logs & Temp ---
*.log
logs/
temp/
hs_err_pid*
replay_pid*

# --- OS Specific ---
.DS_Store
Thumbs.db
